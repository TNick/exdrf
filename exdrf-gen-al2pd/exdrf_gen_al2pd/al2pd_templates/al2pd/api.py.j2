# Aggregate imports for generated al2pd schema modules (optional entrypoint).
# Source: {{ m_name }}
{{- "\n" -}}
from __future__ import annotations

{% for item in al2pd_api_entries -%}
from .{{ item.module_dots }} import (
    {{ item.model_name }},
    {{ item.model_name }}Ex,
    {{ item.model_name }}Create,
{%- if item.generate_edit %}
    {{ item.model_name }}Edit,
{%- endif %}
)

{% endfor -%}
__all__ = [
{%- for item in al2pd_api_entries %}
    "{{ item.model_name }}",
    "{{ item.model_name }}Ex",
    "{{ item.model_name }}Create",
{%- if item.generate_edit %}
    "{{ item.model_name }}Edit",
{%- endif %}
{%- endfor %}
]
