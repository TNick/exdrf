{
  "openapi": "3.1.0",
  "info": {"title": "T", "version": "1"},
  "paths": {
    "/widgets": {
      "get": {
        "tags": ["widgets"],
        "operationId": "list_widgets",
        "responses": {
          "200": {
            "description": "ok",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/WidgetList"}
              }
            }
          }
        }
      },
      "post": {
        "tags": ["widgets"],
        "operationId": "create_widget",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {"$ref": "#/components/schemas/WidgetCreate"}
            }
          }
        },
        "responses": {
          "201": {
            "description": "created",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/WidgetEx"}
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "WidgetCreate": {
        "type": "object",
        "properties": {"name": {"type": "string"}}
      },
      "WidgetEx": {
        "type": "object",
        "properties": {"id": {"type": "string"}, "name": {"type": "string"}}
      },
      "WidgetList": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {"$ref": "#/components/schemas/WidgetEx"}
          }
        }
      }
    }
  }
}
